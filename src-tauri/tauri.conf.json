{
  "$schema": "../ui/node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PC Repair Agent",
  "version": "0.1.0",
  "identifier": "com.pcrepair.agent",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ui -- --host 127.0.0.1 --port 1420 --strictPort",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build --prefix ui",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "PC Repair Agent",
        "width": 1200,
        "height": 756,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
